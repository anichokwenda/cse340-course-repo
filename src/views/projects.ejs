<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>
    <h2>Upcoming Service Projects</h2>
    <p>Browse all upcoming volunteer opportunities from our partner organizations.</p>

    <% if (projects.length === 0) { %>
        <p>No upcoming projects at this time. Check back soon!</p>
    <% } else { %>
        <ul style="list-style: none; padding: 0;">
            <% projects.forEach(project => { %>
                <li style="margin-bottom: 25px; padding: 15px; border: 1px solid #ddd; border-radius: 8px;">
                    <h3 style="margin: 0 0 5px 0;">
                        <%= new Date(project.project_date).toLocaleDateString('en-US', { 
                            year: 'numeric', 
                            month: 'long', 
                            day: 'numeric' 
                        }) %>
                        : <%= project.title %> (<%= project.organization_name %>)
                    </h3>
                    <p style="margin: 5px 0;"><%= project.description %></p>
                    <p style="margin: 5px 0; font-size: 0.9em; color: #555;">
                        <strong>Location:</strong> <%= project.location %>
                    </p>
                </li>
            <% }); %>
        </ul>
    <% } %>
</main>
<%- include('partials/footer') %>