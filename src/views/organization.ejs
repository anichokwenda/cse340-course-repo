<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>

    <h2><%= organizationDetails.name %></h2>
    <img src="/images/<%= organizationDetails.logo_filename %>" alt="<%= organizationDetails.name %> logo" width="150">

    <p><strong>Description:</strong> <%= organizationDetails.description %></p>
    <p><strong>Contact:</strong> <%= organizationDetails.contact_email %></p>

    <h3>Service Projects</h3>
    <% if (projects.length > 0) { %>
        <ul>
            <% projects.forEach(project => { %>
                <li>
                    <a href="/project/<%= project.project_id %>">
                        <%= project.title %>
                    </a> - <%= project.location %> | <%= new Date(project.date).toLocaleDateString() %>
                </li>
            <% }) %>
        </ul>
    <% } else { %>
        <p>No service projects for this organization yet.</p>
    <% } %>
</main>
<%- include('partials/footer') %>